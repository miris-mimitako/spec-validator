{
  "name": "spec-validator",
  "version": "1.0.0",
  "description": "Specification consistency audit and naming validation tooling.",
  "main": "index.js",
  "scripts": {
    "validate:naming:pass": "python .agents/spec-naming-validator/scripts/validate_names.py --path examples/nestjs-pass/src/orders --format text",
    "validate:naming:fail": "python .agents/spec-naming-validator/scripts/validate_names.py --path examples/nestjs-fail/src/orders --format text",
    "report:naming:pass": "python .agents/spec-naming-validator/scripts/validate_names.py --path examples/nestjs-pass/src/orders --format text --report reports/nestjs-pass-report.md --report-format markdown",
    "report:naming:fail": "python .agents/spec-naming-validator/scripts/validate_names.py --path examples/nestjs-fail/src/orders --format text --report reports/nestjs-fail-report.md --report-format markdown",
    "validate:traceability:pass": "python .agents/spec-naming-validator/scripts/validate_traceability.py --implementation-path examples/traceability-pass/src --test-path examples/traceability-pass/test --format text",
    "validate:traceability:fail": "python .agents/spec-naming-validator/scripts/validate_traceability.py --implementation-path examples/traceability-fail/src --test-path examples/traceability-fail/test --format text",
    "report:traceability:pass": "python .agents/spec-naming-validator/scripts/validate_traceability.py --implementation-path examples/traceability-pass/src --test-path examples/traceability-pass/test --format text --report reports/traceability-pass-report.md --report-format markdown",
    "report:traceability:fail": "python .agents/spec-naming-validator/scripts/validate_traceability.py --implementation-path examples/traceability-fail/src --test-path examples/traceability-fail/test --format text --report reports/traceability-fail-report.md --report-format markdown"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miris-mimitako/spec-validator.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/miris-mimitako/spec-validator/issues"
  },
  "homepage": "https://github.com/miris-mimitako/spec-validator#readme",
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
